import type { IconType } from "react-icons"

export interface NavLink {
  label: string
  /** Hash for in-page scroll (e.g. "#features") or route (e.g. "/docs") */
  href: string
  /** External links open in a new tab */
  external?: boolean
}

export interface FeatureItem {
  id: string
  title: string
  description: string
  icon: IconType
}

export interface HowItWorksStep {
  id: string
  step: number
  title: string
  description: string
}

export interface SupportedChain {
  id: string
  name: string
  /** Public logo url or local asset path */
  logo: string
}

export interface WhyReason {
  id: string
  title: string
  description: string
  icon: IconType
}

export interface FaqItem {
  id: string
  question: string
  answer: string
}

export interface CommunityLink {
  id: string
  label: string
  href: string
  icon: IconType
}

export interface StatItem {
  id: string
  /** Numeric target for the counter animation */
  value: number
  suffix?: string
  prefix?: string
  label: string
}
